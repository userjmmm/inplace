{
  "cli": {
    "version": ">= 3.14.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "production-apk": {
      "android": {
        "buildType": "apk",
        "env": {
          "EXPO_USE_COMMUNITY_AUTOLINKING": "0",
          "EXPO_NO_CACHE": "1"
        }
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "env": {
          "EXPO_USE_COMMUNITY_AUTOLINKING": "0",
          "EXPO_NO_CACHE": "1"
        }
      }
    }
  }
}